# ── Required ────────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Anthropic API key from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Quidli Connect API key from https://connect.quid.li
QUIDLI_API_KEY=your_quidli_api_key_here

# ── Optional ─────────────────────────────────────────────────────────────────

CLAUDE_MODEL=claude-sonnet-4-6
SYSTEM_PROMPT=
TELEGRAM_ALLOWED_USERS=
BOT_OWNER_ID=
MASTER_ENCRYPTION_KEY=
BRAVE_SEARCH_API_KEY=
DEFAULT_LLM_PROVIDER=anthropic
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Set to 'true' to require users to connect their own LLM API key before using the bot.
# If 'false' (default), all users share the host's key.
REQUIRE_USER_LLM_KEY=false
BOT_WALLET_PRIVATE_KEY=
BOT_WALLET_ADDRESS=
